{
  "manifest_version": 3,
  "name": "BookSmart",
  "version": "1.0.1",
  "description": "AI-powered bookmark management with semantic search",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "bookmarks",
    "storage",
    "notifications",
    "scripting",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "page": "background.html"
  },
  "chrome_url_overrides": {
    "bookmarks": "bookmarks.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "BookSmart - AI Bookmark Manager"
  },
  "externally_connectable": {
    "matches": [
      "https://booksmart-manager-920600341451.us-central1.run.app/*",
      "https://booksmart-manager-urznzrq37a-uc.a.run.app/*",
      "http://localhost:5173/*"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://booksmart-manager-920600341451.us-central1.run.app/*",
        "https://booksmart-manager-urznzrq37a-uc.a.run.app/*",
        "http://localhost:5173/*"
      ],
      "js": [
        "content-bridge.js"
      ],
      "run_at": "document_start"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "booksmart@bijithore.com",
      "strict_min_version": "109.0"
    }
  }
}