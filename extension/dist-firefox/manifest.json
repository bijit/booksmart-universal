{
  "manifest_version": 3,
  "name": "BookSmart",
  "version": "1.0.1",
  "description": "AI-powered bookmark management with semantic search",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "bookmarks",
    "storage",
    "notifications",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "BookSmart - AI Bookmark Manager"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "booksmart@bijithore.com",
      "strict_min_version": "109.0"
    }
  }
}
