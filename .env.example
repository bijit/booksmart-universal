# ============================================
# BookSmart Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your actual values

# ============================================
# Qdrant Cloud Configuration
# ============================================
# Get from: https://cloud.qdrant.io/
QDRANT_URL=https://your-cluster-id.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_NAME=bookmarks

# ============================================
# Supabase Configuration
# ============================================
# Get from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================
# Google AI Configuration
# ============================================
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Google OAuth (for authentication)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret_here

# Google Embeddings API
# Model: text-embedding-004
GOOGLE_EMBEDDING_MODEL=text-embedding-004

# ============================================
# Jina AI Configuration (Content Extraction)
# ============================================
# Get from: https://jina.ai/ (Optional - works without API key for testing)
JINA_API_KEY=your_jina_api_key_here_optional

# ============================================
# Vercel Configuration (for deployment)
# ============================================
VERCEL_TOKEN=your_vercel_token_here

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
PORT=3000

# API Base URL
API_BASE_URL=http://localhost:3000
MANAGER_BASE_URL=http://localhost:5173

# ============================================
# Feature Flags
# ============================================
ENABLE_PUPPETEER_FALLBACK=false
ENABLE_ANALYTICS=false
ENABLE_DEBUG_LOGGING=true

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Processing Configuration
# ============================================
# Maximum content length to extract (characters)
MAX_CONTENT_LENGTH=10000

# Summary length (words)
SUMMARY_MIN_LENGTH=150
SUMMARY_MAX_LENGTH=300

# Vector dimensions
VECTOR_DIMENSIONS=768

# Background worker polling interval (milliseconds)
WORKER_POLL_INTERVAL=5000

# Maximum retry attempts for failed extractions
MAX_EXTRACTION_RETRIES=3

# ============================================
# Chrome Extension Configuration
# ============================================
# Extension ID (set after publishing to Chrome Web Store)
CHROME_EXTENSION_ID=your_extension_id_here

# ============================================
# Local Development (Docker)
# ============================================
# Uncomment these if using local Docker setup instead of cloud services
# QDRANT_URL=http://localhost:6333
# SUPABASE_URL=http://localhost:54321
