{
  "name": "booksmart-backend",
  "version": "1.0.0",
  "description": "BookSmart backend API server",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write \"src/**/*.js\"",
    "setup:qdrant": "node scripts/setup-qdrant.js",
    "setup:supabase": "node scripts/setup-supabase.js",
    "setup:all": "npm run setup:qdrant && npm run setup:supabase",
    "test:connections": "node scripts/test-connections.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.19.0",
    "@qdrant/js-client-rest": "^1.11.0",
    "@supabase/supabase-js": "^2.45.4",
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "morgan": "^1.10.0",
    "uuid": "^13.0.0",
    "winston": "^3.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "bookmark",
    "ai",
    "vector-search",
    "gemini",
    "qdrant"
  ],
  "author": "",
  "license": "MIT"
}
